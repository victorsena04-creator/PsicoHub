            { "id": "goal-prolabore", "type": "progress-bar", "label": "Pró-Labore Pessoal (Meta: R$ 6.000,00)", "current": "R$ 5.750,00", "percent": 95, "color": "#10b981", "x": 20, "y": 60, "width": 1060 },
            { "id": "goal-custoconsultorio", "type": "progress-bar", "label": "Despesas Operacionais (Meta Limite: R$ 3.000,00)", "current": "R$ 2.450,00", "percent": 81, "color": "#f59e0b", "x": 20, "y": 120, "width": 1060 }
