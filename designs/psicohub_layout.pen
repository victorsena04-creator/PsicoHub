            { "id": "card-realizadas", "type": "card", "title": "Consultas Realizadas", "value": "32 sessões", "color": "#10b981", "x": 300, "y": 0, "width": 280, "height": 100 },
            { "id": "card-cancelamentos", "type": "card", "title": "Cancelamentos / Faltas", "value": "4 (Falta: 3 | Canc: 1)", "color": "#ef4444", "x": 600, "y": 0, "width": 280, "height": 100 },
