            { "id": "card-previsto", "type": "card", "title": "Previsto do Mês", "value": "R$ 12.500,00", "color": "#1e3a5f", "x": 0, "y": 0, "width": 180, "height": 100 },
            { "id": "card-faturado", "type": "card", "title": "Faturado (Emitido)", "value": "R$ 9.800,00", "color": "#475569", "x": 200, "y": 0, "width": 180, "height": 100 },
            { "id": "card-recebido", "type": "card", "title": "Recebido (Caixa)", "value": "R$ 8.200,00", "color": "#10b981", "x": 400, "y": 0, "width": 180, "height": 100 },
