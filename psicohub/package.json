{
  "name": "psicohub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@google/stitch-sdk": "^0.3.5",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.1.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "build": {
    "asar": false,
    "appId": "com.psicohub.app",
    "productName": "PsicoHub",
    "directories": {
      "output": "C:/Users/victo/AppData/Local/Temp/psicohub-build"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!.next/cache/**/*"
    ],
    "win": {
      "icon": "public/psicohub_icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PsicoHub"
    }
  }
}
